# VaultSudo Environment Variables

# --- CORE CONFIGURATION ---
# Set to 'true' to run the application using entirely in-memory data and 
# simulated LLM responses. This requires ZERO external configuration and 
# is perfect for hackathon evaluations, testing, and local demos.
# If 'true', all settings below are completely ignored by the app.
NEXT_PUBLIC_USE_MOCK=true

# --- LLM AGENT CONFIGURATION ---
# Required if NEXT_PUBLIC_USE_MOCK=false
OPENAI_API_KEY=sk-proj-... # Or Anthropic depending on chosen provider

# --- AUTH0 (CIBA & Step-Up Auth) ---
# Required if NEXT_PUBLIC_USE_MOCK=false
AUTH0_SECRET=generate_a_random_32_byte_string_here
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret

# --- SUPABASE (Immutable Audit Trail) ---
# Required if NEXT_PUBLIC_USE_MOCK=false
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhb...
